# ── Services ──────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=scholar_rag
# To use a Qdrant Cloud cluster instead (e.g. one built by the Colab notebook),
# set these two — they take precedence over QDRANT_HOST/PORT. Put the REAL values
# only in your local .env (which is gitignored), never in this committed template:
QDRANT_URL=
QDRANT_API_KEY=

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b          # or qwen2.5:7b / mistral:7b
OLLAMA_EMBED_MODEL=nomic-embed-text  # fallback local embed

# ── "Deep Retrieval using GPU" backend (optional) ─────────────────────────────
# Route deep-mode LLM steps to a free hosted API (Groq) or a self-hosted GPU
# Ollama. Leave all blank = deep mode runs on local CPU.
DEEP_LLM_API_KEY=                        # Groq key from https://console.groq.com/keys
DEEP_LLM_BASE_URL=https://api.groq.com/openai/v1
DEEP_LLM_MODEL=llama-3.3-70b-versatile
OLLAMA_DEEP_URL=                         # alt: self-hosted GPU Ollama endpoint
OLLAMA_DEEP_MODEL=llama3.1:8b

# ── Reranker: hosted Jina API (optional; recommended on low-RAM machines) ─────
# When set, reranking runs on Jina's API instead of the 2 GB local cross-encoder.
# Free key: https://jina.ai/reranker . Leave blank to use BGE_RERANKER_MODEL.
JINA_API_KEY=
JINA_RERANKER_MODEL=jina-reranker-v2-base-multilingual

GROBID_URL=http://localhost:8070

MLFLOW_TRACKING_URI=http://localhost:5001
MLFLOW_EXPERIMENT=scholar_rag

# ── External APIs (all free, no key required) ─────────────────────────────────
# Citation enrichment uses OpenAlex only — free, no API key, generous limits.
# It asks that you identify yourself in the User-Agent "polite pool"; set a real
# contact address here and it will be used instead of the default.
OPENALEX_MAILTO=scholar@example.com

# ── Paths ──────────────────────────────────────────────────────────────────────
DATA_RAW_DIR=data/raw
DATA_PARSED_DIR=data/parsed
DATA_EVAL_DIR=data/eval

# ── Model paths (HuggingFace cache or local) ──────────────────────────────────
BGE_M3_MODEL=BAAI/bge-m3
BGE_RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ── Retrieval hyper-parameters ────────────────────────────────────────────────
RETRIEVAL_TOP_K=50          # candidates before rerank
RERANK_TOP_K=10             # passages sent to generator
HYDE_ENABLED=true
MULTI_QUERY_N=3
GRAPH_RERANK_ALPHA=0.6      # reranker weight
GRAPH_RERANK_BETA=0.25      # citation-influence weight
GRAPH_RERANK_GAMMA=0.15     # recency weight
